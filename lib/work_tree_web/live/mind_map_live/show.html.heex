<div
  id="mind-map-container"
  class="mind-map-container"
  phx-window-keydown="keydown"
  phx-hook="DisableTab"
>
  <%!-- Breadcrumb navigation --%>
  <div :if={@ancestors != []} class="mind-map-breadcrumb">
    <.link navigate={~p"/"} class="text-base-content/60 hover:text-primary">
      Home
    </.link>
    <span :for={ancestor <- @ancestors} class="flex items-center">
      <span class="mx-2 text-base-content/40">/</span>
      <.link navigate={~p"/node/#{ancestor.id}"} class="text-base-content/60 hover:text-primary">
        <%= ancestor.title %>
      </.link>
    </span>
    <span class="mx-2 text-base-content/40">/</span>
    <span class="font-medium"><%= @root.title %></span>
  </div>

  <%!-- Toolbar --%>
  <div class="mind-map-toolbar">
    <.link :if={@ancestors != []} navigate={~p"/"} class="btn btn-ghost btn-sm">
      <span class="text-lg">←</span> Home
    </.link>
    <button phx-click="add_node_inline" class="btn btn-primary btn-sm">
      + Add Node
    </button>
    <div class="flex-1"></div>
    <div class="dropdown dropdown-end">
      <div tabindex="0" role="button" class="btn btn-ghost btn-sm gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
        </svg>
        Theme
      </div>
      <ul tabindex="0" class="dropdown-content menu bg-base-200 rounded-box z-50 w-44 p-2 shadow-lg max-h-80 overflow-y-auto">
        <li class="menu-title text-xs">System</li>
        <li><button data-phx-theme="system" phx-click={JS.dispatch("phx:set-theme")}>Auto</button></li>
        <li class="menu-title text-xs mt-2">Light Themes</li>
        <li><button data-phx-theme="light" phx-click={JS.dispatch("phx:set-theme")}>Light</button></li>
        <li><button data-phx-theme="cupcake" phx-click={JS.dispatch("phx:set-theme")}>Cupcake</button></li>
        <li><button data-phx-theme="bumblebee" phx-click={JS.dispatch("phx:set-theme")}>Bumblebee</button></li>
        <li><button data-phx-theme="emerald" phx-click={JS.dispatch("phx:set-theme")}>Emerald</button></li>
        <li><button data-phx-theme="corporate" phx-click={JS.dispatch("phx:set-theme")}>Corporate</button></li>
        <li><button data-phx-theme="retro" phx-click={JS.dispatch("phx:set-theme")}>Retro</button></li>
        <li><button data-phx-theme="garden" phx-click={JS.dispatch("phx:set-theme")}>Garden</button></li>
        <li><button data-phx-theme="lofi" phx-click={JS.dispatch("phx:set-theme")}>Lofi</button></li>
        <li><button data-phx-theme="pastel" phx-click={JS.dispatch("phx:set-theme")}>Pastel</button></li>
        <li><button data-phx-theme="fantasy" phx-click={JS.dispatch("phx:set-theme")}>Fantasy</button></li>
        <li><button data-phx-theme="wireframe" phx-click={JS.dispatch("phx:set-theme")}>Wireframe</button></li>
        <li><button data-phx-theme="cmyk" phx-click={JS.dispatch("phx:set-theme")}>CMYK</button></li>
        <li><button data-phx-theme="autumn" phx-click={JS.dispatch("phx:set-theme")}>Autumn</button></li>
        <li><button data-phx-theme="acid" phx-click={JS.dispatch("phx:set-theme")}>Acid</button></li>
        <li><button data-phx-theme="lemonade" phx-click={JS.dispatch("phx:set-theme")}>Lemonade</button></li>
        <li><button data-phx-theme="winter" phx-click={JS.dispatch("phx:set-theme")}>Winter</button></li>
        <li><button data-phx-theme="nord" phx-click={JS.dispatch("phx:set-theme")}>Nord</button></li>
        <li class="menu-title text-xs mt-2">Dark Themes</li>
        <li><button data-phx-theme="dark" phx-click={JS.dispatch("phx:set-theme")}>Dark</button></li>
        <li><button data-phx-theme="synthwave" phx-click={JS.dispatch("phx:set-theme")}>Synthwave</button></li>
        <li><button data-phx-theme="cyberpunk" phx-click={JS.dispatch("phx:set-theme")}>Cyberpunk</button></li>
        <li><button data-phx-theme="valentine" phx-click={JS.dispatch("phx:set-theme")}>Valentine</button></li>
        <li><button data-phx-theme="halloween" phx-click={JS.dispatch("phx:set-theme")}>Halloween</button></li>
        <li><button data-phx-theme="forest" phx-click={JS.dispatch("phx:set-theme")}>Forest</button></li>
        <li><button data-phx-theme="aqua" phx-click={JS.dispatch("phx:set-theme")}>Aqua</button></li>
        <li><button data-phx-theme="black" phx-click={JS.dispatch("phx:set-theme")}>Black</button></li>
        <li><button data-phx-theme="luxury" phx-click={JS.dispatch("phx:set-theme")}>Luxury</button></li>
        <li><button data-phx-theme="dracula" phx-click={JS.dispatch("phx:set-theme")}>Dracula</button></li>
        <li><button data-phx-theme="business" phx-click={JS.dispatch("phx:set-theme")}>Business</button></li>
        <li><button data-phx-theme="night" phx-click={JS.dispatch("phx:set-theme")}>Night</button></li>
        <li><button data-phx-theme="coffee" phx-click={JS.dispatch("phx:set-theme")}>Coffee</button></li>
        <li><button data-phx-theme="dim" phx-click={JS.dispatch("phx:set-theme")}>Dim</button></li>
        <li><button data-phx-theme="sunset" phx-click={JS.dispatch("phx:set-theme")}>Sunset</button></li>
      </ul>
    </div>
  </div>

  <%!-- Canvas --%>
  <div
    id="mind-map-canvas"
    class="mind-map-canvas"
    style={"min-width: #{@canvas_width}px; min-height: #{@canvas_height}px;"}
  >
    <%!-- SVG layer for edges --%>
    <svg
      class="mind-map-svg"
      style={"width: #{@canvas_width}px; height: #{@canvas_height}px;"}
    >
      <defs>
        <marker
          id="arrowhead"
          markerWidth="10"
          markerHeight="7"
          refX="9"
          refY="3.5"
          orient="auto"
        >
          <polygon points="0 0, 10 3.5, 0 7" fill="currentColor" class="text-base-300" />
        </marker>
      </defs>
      <%= for edge <- @edges do %>
        <g class={"mind-map-edge-group #{if edge.source_id == @focused_node_id or edge.target_id == @focused_node_id, do: "focused"}"}>
          <path
            d={edge_path(edge)}
            class="mind-map-edge"
          />
          <%= if edge.label do %>
            <text
              x={(edge.source_x + edge.target_x) / 2}
              y={(edge.source_y + edge.target_y) / 2 - 8}
              class="mind-map-edge-label"
            >
              <%= edge.label %>
            </text>
          <% end %>
        </g>
      <% end %>
    </svg>

    <%!-- DOM layer for nodes --%>
    <%= for node <- @nodes do %>
      <% pos = @node_positions[node.id] %>
      <div
        id={"node-#{node.id}"}
        class={[
          "mind-map-node",
          @focused_node_id == node.id && "focused",
          @selected_node && @selected_node.id == node.id && "selected",
          node.is_todo && "todo",
          node.is_todo && node.todo_completed && "completed",
          @editing_node_id == node.id && "editing"
        ]}
        style={"left: #{pos.x}px; top: #{pos.y}px; width: #{pos.width}px;"}
        phx-click="focus_node"
        phx-value-id={node.id}
        phx-hook="NodeContextMenu"
        data-node-id={node.id}
      >
        <%= if @editing_node_id == node.id do %>
          <form phx-submit="save_inline_edit" phx-value-id={node.id}>
            <input
              type="text"
              name="title"
              value={node.title}
              class="mind-map-inline-input"
              phx-hook="FocusEnd"
              id={"inline-edit-#{node.id}"}
              phx-keydown="cancel_inline_edit"
              phx-key="Escape"
              phx-value-id={node.id}
              phx-blur="blur_inline_edit"
              autocomplete="off"
            />
          </form>
        <% else %>
          <div class="mind-map-node-title">
            <%= node.title %>
          </div>
        <% end %>
        <div :if={node.is_todo} class="mind-map-todo-indicator">
          <%= if node.todo_completed, do: "✓", else: "○" %>
        </div>
      </div>
    <% end %>
  </div>

  <%!-- Keyboard shortcuts hint --%>
  <div class="mind-map-hints">
    <span class="kbd kbd-xs">h</span><span class="kbd kbd-xs">j</span><span class="kbd kbd-xs">k</span><span class="kbd kbd-xs">l</span> navigate
    <span class="mx-2">·</span>
    <span class="kbd kbd-xs">Enter</span> details
    <span class="mx-2">·</span>
    <span class="kbd kbd-xs">o</span> add
    <span class="mx-2">·</span>
    <span class="kbd kbd-xs">f</span> focus
    <span class="mx-2">·</span>
    <span class="kbd kbd-xs">t</span> toggle todo
    <span class="mx-2">·</span>
    <span class="kbd kbd-xs">⌫</span> delete
  </div>

  <%!-- Undo toast notification --%>
  <div
    :if={@deleted_node}
    class="mind-map-undo-toast"
    phx-mounted={JS.transition({"ease-out duration-300", "opacity-0 translate-y-4", "opacity-100 translate-y-0"})}
  >
    <span class="flex items-center gap-2">
      <span class="text-error">✕</span>
      Deleted "<%= @deleted_node.title %>"
    </span>
    <div class="flex gap-2">
      <button phx-click="undo_delete" class="btn btn-sm btn-primary">
        Undo
      </button>
      <button phx-click="dismiss_undo" class="btn btn-sm btn-ghost">
        Dismiss
      </button>
    </div>
  </div>
</div>

<%!-- Node detail modal --%>
<.modal :if={@selected_node} id="node-detail-modal" show on_cancel={JS.push("close_detail")}>
  <div class="space-y-4">
    <div class="flex justify-between items-start">
      <h3 class="text-xl font-semibold flex items-center gap-2">
        <span :if={@selected_node.is_todo} class={"text-lg #{if @selected_node.todo_completed, do: "text-success", else: "text-base-content/50"}"}>
          <%= if @selected_node.todo_completed, do: "☑", else: "☐" %>
        </span>
        <%= @selected_node.title %>
      </h3>
    </div>

    <div :if={@selected_node.body["content"]} class="prose prose-sm">
      <p><%= @selected_node.body["content"] %></p>
    </div>

    <div :if={@selected_node.edge_label} class="text-sm text-base-content/60">
      <span class="font-medium">Edge label:</span> <%= @selected_node.edge_label %>
    </div>

    <div class="border-t border-base-300 pt-4 flex flex-wrap gap-2">
      <.link
        patch={~p"/node/#{@root.id}/edit/#{@selected_node.id}"}
        class="btn btn-sm btn-ghost"
      >
        Edit
      </.link>
      <button
        :if={@selected_node.is_todo}
        phx-click="toggle_todo"
        phx-value-id={@selected_node.id}
        class="btn btn-sm btn-ghost"
      >
        <%= if @selected_node.todo_completed, do: "Mark incomplete", else: "Mark complete" %>
      </button>
      <button
        phx-click="focus_subtree"
        phx-value-id={@selected_node.id}
        class="btn btn-sm btn-ghost"
      >
        Focus subtree
      </button>
      <button
        :if={@selected_node.id != @root.id}
        phx-click="delete_node"
        phx-value-id={@selected_node.id}
        class="btn btn-sm btn-ghost text-error"
      >
        Delete
      </button>
    </div>
  </div>
</.modal>

<%!-- Edit node modal --%>
<.modal :if={@modal_action == :edit} id="node-form-modal" show on_cancel={JS.patch(~p"/node/#{@root.id}")}>
  <.live_component
    module={WorkTreeWeb.MindMapLive.NodeFormComponent}
    id={@form_node.id || :new}
    title="Edit Node"
    action={@modal_action}
    node={@form_node}
    parent_id={@focused_node_id}
    patch={~p"/node/#{@root.id}"}
  />
</.modal>
