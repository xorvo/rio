#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
RESOURCES="$SCRIPT_DIR/../Resources"
SIDECAR="$RESOURCES/sidecar"
RELEASE_BIN="$SIDECAR/bin/desktop"

# Data directory (persists across updates)
export WORK_TREE_DATA_DIR="${HOME}/Library/Application Support/WorkTree"
mkdir -p "$WORK_TREE_DATA_DIR"

# Pick a random available port
PORT=$(python3 -c 'import socket; s=socket.socket(); s.bind(("",0)); print(s.getsockname()[1]); s.close()')

# Configure the Phoenix release
export PORT="$PORT"
export WORK_TREE_DESKTOP=true
export PHX_SERVER=true
export RELEASE_TMP="$(mktemp -d)"
export RELEASE_NODE="desktop_$$"

# Start Phoenix in the background
"$RELEASE_BIN" start &
PHOENIX_PID=$!

# Wait for Phoenix to be ready (up to 30s)
for i in $(seq 1 60); do
  if curl -s -o /dev/null "http://localhost:$PORT" 2>/dev/null; then
    break
  fi
  sleep 0.5
done

# Open Chrome in app mode (standalone window, no tabs/address bar)
# Falls back to default browser if Chrome isn't installed
CHROME="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
if [ -x "$CHROME" ]; then
  "$CHROME" --app="http://localhost:$PORT" \
    --user-data-dir="$WORK_TREE_DATA_DIR/chrome-profile"
else
  open "http://localhost:$PORT"
fi

# When Chrome window closes, stop Phoenix
"$RELEASE_BIN" stop 2>/dev/null || kill $PHOENIX_PID 2>/dev/null
rm -rf "$RELEASE_TMP"
